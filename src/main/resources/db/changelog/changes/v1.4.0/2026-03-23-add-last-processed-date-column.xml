<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">

  <changeSet id="addBatchRequestProcessedAtColumn" author="Copilot">
    <preConditions onFail="MARK_RAN">
      <and>
        <tableExists tableName="batch_request"/>
        <not>
          <columnExists tableName="batch_request" columnName="last_processed_date"/>
        </not>
      </and>
    </preConditions>

    <addColumn tableName="batch_request">
      <column name="last_processed_date" type="timestamp without time zone"/>
    </addColumn>
  </changeSet>

</databaseChangeLog>
